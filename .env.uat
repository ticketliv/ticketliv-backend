# ticketliv-backend uat configuration
NODE_ENV=uat
PORT=5000
DATABASE_URL=postgresql://uat_user:uat_pass@uat-db.ticketliv.com:5432/ticketliv_uat
JWT_SECRET=uat_secret_key_789
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=uat_refresh_secret_abc
REFRESH_TOKEN_EXPIRES_IN=7d
REDIS_URL=redis://uat-cache.ticketliv.com:6379

# Email Config (UAT)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=uat_sendgrid_key
