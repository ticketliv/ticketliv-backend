# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=ticketliv
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=ticketliv-dev-jwt-secret-2026
JWT_REFRESH_SECRET=ticketliv-dev-refresh-secret-2026
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# QR Ticket Security
QR_SIGNING_SECRET=ticketliv-qr-signing-dev
QR_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Frontend URLs (CORS)
ADMIN_URL=http://localhost:5173
ORGANIZER_URL=http://localhost:5174
MOBILE_URL=http://localhost:19006

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
