# ticketliv-backend production configuration
NODE_ENV=production
PORT=5000
DATABASE_URL=postgresql://prod_user:prod_pass@db.ticketliv.com:5432/ticketliv_prod
JWT_SECRET=replace_with_strong_random_secret
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=replace_with_strong_refresh_secret
REFRESH_TOKEN_EXPIRES_IN=7d
REDIS_URL=redis://cache.ticketliv.com:6379

# Email Config (Production)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=prod_sendgrid_key
